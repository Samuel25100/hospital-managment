

model User {
  id             String    @id @default(cuid())
  clerkId        String    @unique
  tenantId       String?
  name           String
  email          String    @unique
  emailVerified  Boolean   @default(false)
  phone          String?
  passwordHash   String?
  roleId         String?
  isActive       Boolean   @default(true)
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([tenantId])
  @@index([email])
  @@index([roleId])
  @@map("users")
}
