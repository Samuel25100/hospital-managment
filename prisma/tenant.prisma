enum TenantStatus {
	active
	suspended
	cancelled
}

model Tenant {
	id             String       @id @default(cuid())
	name           String
	slug           String       @unique
	email          String
	phone          String
	status         TenantStatus @default(active)
	subscriptionId String
	createdAt      DateTime     @default(now())
	updatedAt      DateTime     @updatedAt
	@@map("tenants")
}
