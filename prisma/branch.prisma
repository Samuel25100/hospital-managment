// =======================
// BRANCH
// =======================


model Branch {
  id          String   @id
  tenantId    String
  clinicId    String
  name        String
  code        String
  phone       String
  addressId   String
  managerId   String?
  status      Status   @default(active)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  departments Department[]
  wards       Ward[]
  rooms       Room[]
  @@map("branches")
}