// =======================
// DEPARTMENT
// =======================


model Department {
  id            String   @id
  tenantId      String
  branchId      String
  clinicId      String

  name          String
  code          String
  description   String?
  headStaffId   String?

  status        Status   @default(active)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  branch         Branch @relation(fields: [branchId], references: [id])

  wards          Ward[]
  rooms          Room[]
  @@map("departments")
}